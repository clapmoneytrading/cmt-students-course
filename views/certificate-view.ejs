<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Certificate Verification | CMT</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="auth-wrap">
      <section class="card cert-view">
        <div class="auth-brand">
          <img src="/logo.svg" alt="Clap Money Trading" class="brand-logo" />
          <p class="brand-subtitle">Clap Money Trading</p>
        </div>
        <h1>Certificate Verified</h1>
        <p class="muted">This certificate link belongs to:</p>
        <p><strong><%= student.name %></strong></p>
        <p class="muted"><%= student.email %></p>
      </section>
    </main>
  </body>
</html>
