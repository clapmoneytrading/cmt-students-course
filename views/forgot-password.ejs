<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password | CMT Students</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="auth-wrap">
      <section class="card">
        <div class="auth-brand">
          <img src="/logo.svg" alt="Clap Money Trading" class="brand-logo" />
          <p class="brand-subtitle">Clap Money Trading</p>
        </div>

        <h1>Forgot Password</h1>
        <p class="muted">Enter your email to receive a reset link.</p>

        <% if (error) { %>
          <div class="alert"><%= error %></div>
        <% } %>
        <% if (message) { %>
          <div class="alert success"><%= message %></div>
        <% } %>

        <form method="post" action="/forgot-password" class="form-grid">
          <label>Email</label>
          <input type="email" name="email" required />

          <button type="submit">Send Reset Link</button>
        </form>

        <p class="helper"><a href="/login">Back to Login</a></p>
      </section>
    </main>
  </body>
</html>
