<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login | CMT Students</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="auth-wrap">
      <section class="card">
        <div class="auth-brand">
          <img src="/logo.svg" alt="Clap Money Trading" class="brand-logo" />
          <p class="brand-subtitle">Clap Money Trading</p>
        </div>
        <h1>Student Login</h1>
        <p class="muted">Login to access your free and paid courses.</p>

        <% if (message === 'register_success') { %>
          <div class="alert success">Registration successful. You can login now.</div>
        <% } %>
        <% if (message === 'otp_disabled') { %>
          <div class="alert">OTP verification is disabled. Please login with your email and password.</div>
        <% } %>
        <% if (message === 'reset_success') { %>
          <div class="alert success">Password reset complete. Please login.</div>
        <% } %>

        <% if (error) { %>
          <div class="alert"><%= error %></div>
        <% } %>

        <form method="post" action="/login" class="form-grid">
          <label>Email</label>
          <input type="email" name="email" required />

          <label>Password</label>
          <input type="password" name="password" required />

          <button type="submit">Login</button>
        </form>

        <p class="helper">No account? <a href="/register">Register here</a></p>
        <p class="helper"><a href="/forgot-password">Forgot password?</a></p>
      </section>
    </main>
  </body>
</html>
