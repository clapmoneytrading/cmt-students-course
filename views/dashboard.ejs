<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard | CMT Students</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="topbar">
      <div class="brand">
        <img src="/logo.svg" alt="Clap Money Trading" class="brand-logo" />
        <div>
          <h1 class="brand-title">Clap Money Trading</h1>
          <p class="brand-subtitle">Welcome, <%= currentUser.name %></p>
        </div>
      </div>
      <div class="topbar-actions">
        <a href="/announcements" class="btn-link">Announcement</a>
        <a href="/help" class="btn-link">Help</a>
        <% if (currentUser.is_admin) { %>
          <a href="/admin" class="btn-link">Admin Panel</a>
        <% } %>
        <form method="post" action="/logout">
          <button type="submit" class="danger">Logout</button>
        </form>
      </div>
    </header>

    <main class="container">
      <section class="card hero-banner">
        <div class="hero-head">
          <div>
            <p class="status-line">
              Access: <strong><%= currentUser.has_paid_access ? "Paid + Free" : "Free" %></strong>
            </p>
            <h2>Your Progress</h2>
            <p class="muted">
              Completed <strong><%= completion.completedLessons %></strong> of <strong><%= completion.totalLessons %></strong>
              lessons.
            </p>
          </div>
          <div class="progress-ring-wrap">
            <div class="progress-ring" style="--percent: <%= completion.completionPercent %>">
              <span><%= completion.completionPercent %>%</span>
            </div>
          </div>
        </div>
        <div class="progress-track large">
          <div class="progress-fill" style="width: <%= completion.completionPercent %>%"></div>
        </div>
      </section>

      <section class="card roadmap-card">
        <h2>Roadmap</h2>
        <div class="roadmap">
          <% roadmap.forEach((step) => {
               const hasBadge = completion.badges.some((b) => b.startsWith(step.toUpperCase()));
          %>
            <div class="road-step <%= hasBadge ? 'road-step-done' : '' %>">
              <span><%= step.toUpperCase() %></span>
            </div>
          <% }) %>
        </div>
        <div class="badge-row">
          <% if (!completion.badges.length) { %>
            <p class="muted">No milestone badges yet. Complete a module to earn badges.</p>
          <% } else { %>
            <% completion.badges.forEach((badge) => { %>
              <span class="badge-pill"><%= badge %> Badge</span>
            <% }) %>
          <% } %>
        </div>

        <% if (certificateToken) { %>
          <div class="certificate-actions">
            <a href="/certificate/download" class="btn-link">Download Certificate PDF</a>
            <button type="button" id="shareCertBtn">Copy Share Link</button>
            <span id="shareCertMsg" class="muted"></span>
          </div>
        <% } %>
      </section>

      <% if (freeGroupUrl || (currentUser.has_paid_access && paidGroupUrl)) { %>
        <section class="card callout">
          <h2>WhatsApp Learning Groups</h2>
          <p class="muted">You can stay in Free group and, after paid access, also join Paid group.</p>
          <div class="topbar-actions">
            <% if (freeGroupUrl) { %>
              <a href="<%= freeGroupUrl %>" target="_blank" rel="noopener" class="btn-link">Join Free Group</a>
            <% } %>
            <% if (currentUser.has_paid_access && paidGroupUrl) { %>
              <a href="<%= paidGroupUrl %>" target="_blank" rel="noopener" class="btn-link">Join Paid Group</a>
            <% } %>
          </div>
        </section>
      <% } %>

      <% if (continueWatching.length) { %>
        <section class="card">
          <h2>Continue Watching</h2>
          <div class="continue-grid">
            <% continueWatching.forEach((video) => { %>
              <article class="continue-card">
                <h3 class="thumb-title"><%= video.title %></h3>
                <p class="muted"><%= video.topic || 'General Topic' %> | <%= (video.level || 'beginner').toUpperCase() %></p>
                <div class="progress-track">
                  <div class="progress-fill" style="width: <%= video.progress_percent %>%"></div>
                </div>
                <p class="muted">Progress: <%= video.progress_percent %>%</p>
                <a href="#lesson-<%= video.id %>" class="btn-link">Resume Lesson</a>
              </article>
            <% }) %>
          </div>
        </section>
      <% } %>

      <section class="card">
        <h2>Find Lessons</h2>
        <div class="filter-bar">
          <input id="lessonSearch" type="text" placeholder="Search by lesson title or topic" />
          <select id="topicFilter">
            <option value="">All Topics</option>
            <% topicOptions.forEach((topic) => { %>
              <option value="<%= topic %>"><%= topic %></option>
            <% }) %>
          </select>
          <select id="levelFilter">
            <option value="">All Levels</option>
            <% levelOptions.forEach((level) => { %>
              <option value="<%= level %>"><%= level.toUpperCase() %></option>
            <% }) %>
          </select>
        </div>
      </section>

      <section class="card">
        <h2>Course Modules</h2>
        <% if (!modules.length) { %>
          <p class="muted">No modules available yet. Ask admin to add course content.</p>
        <% } else { %>
          <div class="course-shell">
            <div class="course-tree">
              <% modules.forEach((module) => { %>
                <article class="module-card <%= module.locked ? 'module-locked' : '' %>">
                  <div class="module-head">
                    <h3><%= module.title %></h3>
                    <div class="module-head-actions">
                      <span class="pill <%= module.access_type === 'paid' ? 'pill-paid' : 'pill-free' %>"><%= module.access_type.toUpperCase() %></span>
                      <% if (!module.locked && module.lessons.length) { %>
                        <button type="button" class="module-toggle" data-module-toggle aria-expanded="true">Collapse</button>
                      <% } %>
                    </div>
                  </div>
                  <% if (module.locked) { %>
                    <p class="locked-note">
                      This module is locked.
                      <% if (module.access_type === 'paid') { %>
                        Price: <strong><%= Number(module.price_amount || 0).toFixed(2) %></strong>.
                        <a href="/pay?module_id=<%= module.id %>" class="btn-link">Unlock This Module</a>
                      <% } %>
                    </p>
                  <% } else if (!module.lessons.length) { %>
                    <p class="muted">No lessons in this module yet.</p>
                  <% } else { %>
                    <ul class="topic-list">
                      <% module.lessons.forEach((video) => {
                           const p = progressByVideo[video.id] || { progress_seconds: 0, duration_seconds: 0, completed: false };
                      %>
                        <li id="lesson-<%= video.id %>">
                          <button
                            type="button"
                            class="topic-item"
                            data-video-id="<%= video.id %>"
                            data-title="<%= video.title %>"
                            data-description="<%= video.description || '' %>"
                            data-topic="<%= video.topic || 'General Topic' %>"
                            data-level="<%= (video.level || 'beginner').toLowerCase() %>"
                            data-access="<%= video.access_type %>"
                            data-source-type="<%= video.source_type %>"
                            data-youtube-url="<%= video.youtube_url || '' %>"
                            data-video-src="/video/<%= video.id %>"
                            data-start-seconds="<%= p.progress_seconds || 0 %>"
                            data-completed="<%= p.completed ? '1' : '0' %>"
                          >
                            <span class="topic-title"><%= video.title %></span>
                            <span class="topic-meta"><%= video.topic || 'General Topic' %> | <%= (video.level || 'beginner').toUpperCase() %></span>
                            <span class="topic-progress" data-progress-label="<%= video.id %>"><%= p.completed ? 'Completed' : 'Progress saved' %></span>
                          </button>
                        </li>
                      <% }) %>
                    </ul>
                  <% } %>
                </article>
              <% }) %>
            </div>

            <div class="course-player-panel">
              <h3 id="activeLessonTitle">Select a topic to start</h3>
              <p id="activeLessonMeta" class="muted">Choose any topic from the left module list.</p>
              <p id="activeLessonDesc" class="muted"></p>
              <div id="lessonPlayerHost" class="lesson-media-wrap lesson-player-host"></div>
              <button id="panelCompleteBtn" type="button" class="mark-complete-btn" style="display:none;">Mark as Complete</button>
            </div>
          </div>
        <% } %>
      </section>
    </main>

    <script>
      (function () {
        const searchInput = document.getElementById("lessonSearch");
        const topicFilter = document.getElementById("topicFilter");
        const levelFilter = document.getElementById("levelFilter");
        const topicItems = document.querySelectorAll(".topic-item");
        const moduleToggles = document.querySelectorAll("[data-module-toggle]");
        const lessonTitleEl = document.getElementById("activeLessonTitle");
        const lessonMetaEl = document.getElementById("activeLessonMeta");
        const lessonDescEl = document.getElementById("activeLessonDesc");
        const lessonPlayerHost = document.getElementById("lessonPlayerHost");
        const panelCompleteBtn = document.getElementById("panelCompleteBtn");
        const shareCertBtn = document.getElementById("shareCertBtn");
        const shareCertMsg = document.getElementById("shareCertMsg");
        let currentVideoEl = null;

        function applyFilters() {
          const q = (searchInput && searchInput.value ? searchInput.value : "").trim().toLowerCase();
          const topic = (topicFilter && topicFilter.value ? topicFilter.value : "").trim().toLowerCase();
          const level = (levelFilter && levelFilter.value ? levelFilter.value : "").trim().toLowerCase();

          topicItems.forEach(function (btn) {
            const title = (btn.getAttribute("data-title") || "").toLowerCase();
            const itemTopic = (btn.getAttribute("data-topic") || "").toLowerCase();
            const itemLevel = (btn.getAttribute("data-level") || "").toLowerCase();
            const li = btn.closest("li");

            const passSearch = !q || title.indexOf(q) >= 0 || itemTopic.indexOf(q) >= 0;
            const passTopic = !topic || itemTopic === topic;
            const passLevel = !level || itemLevel === level;

            if (li) {
              li.style.display = passSearch && passTopic && passLevel ? "list-item" : "none";
            }
          });
        }

        function setWatermark(wmEl) {
          if (!wmEl) {
            return;
          }
          wmEl.textContent = "<%= currentUser.email %> | " + new Date().toLocaleString();
          wmEl.style.left = (8 + Math.round(Math.random() * 55)) + "%";
          wmEl.style.top = (8 + Math.round(Math.random() * 70)) + "%";
        }

        function postProgress(videoEl, completedFlag) {
          const videoId = videoEl.getAttribute("data-video-id");
          if (!videoId) {
            return;
          }

          const params = new URLSearchParams();
          params.set("progress_seconds", String(videoEl.currentTime || 0));
          params.set("duration_seconds", String(videoEl.duration || 0));
          params.set("completed", completedFlag ? "1" : "0");

          fetch("/api/progress/" + videoId, {
            method: "POST",
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body: params.toString()
          }).catch(function () {});

          const label = document.querySelector('[data-progress-label="' + videoId + '"]');
          if (label) {
            if (completedFlag) {
              label.textContent = "Completed";
            } else {
              const percent = videoEl.duration > 0 ? Math.round((videoEl.currentTime / videoEl.duration) * 100) : 0;
              label.textContent = "Progress: " + percent + "%";
            }
          }
        }

        function markLessonComplete(videoId, buttonEl) {
          const params = new URLSearchParams();
          params.set("progress_seconds", "1");
          params.set("duration_seconds", "1");
          params.set("completed", "1");

          fetch("/api/progress/" + videoId, {
            method: "POST",
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body: params.toString()
          })
            .then(function (r) { return r.json(); })
            .then(function (payload) {
              if (!payload || !payload.ok) {
                return;
              }
              const label = document.querySelector('[data-progress-label="' + videoId + '"]');
              if (label) {
                label.textContent = "Completed";
              }
              const item = document.querySelector('.topic-item[data-video-id="' + videoId + '"]');
              if (item) {
                item.setAttribute("data-completed", "1");
              }
              if (buttonEl) {
                buttonEl.disabled = true;
                buttonEl.textContent = "Completed";
              }
            })
            .catch(function () {});
        }

        function attachVideoTracking(videoEl) {
          let lastSentAt = 0;
          const resumeAt = Number(videoEl.getAttribute("data-start-seconds") || 0);
          const wmEl = lessonPlayerHost.querySelector("[data-watermark]");

          videoEl.addEventListener("loadedmetadata", function () {
            if (resumeAt > 0 && resumeAt < videoEl.duration - 2) {
              videoEl.currentTime = resumeAt;
            }
            setWatermark(wmEl);
          });

          videoEl.addEventListener("timeupdate", function () {
            const now = Date.now();
            if (now - lastSentAt > 10000) {
              lastSentAt = now;
              postProgress(videoEl, false);
              setWatermark(wmEl);
            }
          });

          videoEl.addEventListener("pause", function () { postProgress(videoEl, false); });
          videoEl.addEventListener("ended", function () { postProgress(videoEl, true); });
          videoEl.addEventListener("contextmenu", function (e) { e.preventDefault(); });
          videoEl.addEventListener("dragstart", function (e) { e.preventDefault(); });
        }

        function selectTopic(button) {
          topicItems.forEach(function (btn) { btn.classList.remove("active-topic"); });
          button.classList.add("active-topic");

          const videoId = button.getAttribute("data-video-id");
          const title = button.getAttribute("data-title") || "Lesson";
          const description = button.getAttribute("data-description") || "";
          const topic = button.getAttribute("data-topic") || "General Topic";
          const level = (button.getAttribute("data-level") || "beginner").toUpperCase();
          const sourceType = button.getAttribute("data-source-type") || "upload";
          const youtubeUrl = button.getAttribute("data-youtube-url") || "";
          const videoSrc = button.getAttribute("data-video-src") || "";
          const startSeconds = button.getAttribute("data-start-seconds") || "0";
          const completed = button.getAttribute("data-completed") === "1";

          lessonTitleEl.textContent = title;
          lessonMetaEl.textContent = topic + " | " + level;
          lessonDescEl.textContent = description;
          lessonPlayerHost.innerHTML = "";
          currentVideoEl = null;

          if (sourceType === "youtube" && youtubeUrl) {
            lessonPlayerHost.innerHTML =
              '<iframe class="lesson-embed" src="' + youtubeUrl + '" title="' + title + '" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>' +
              '<p class="muted">Hosted on YouTube.</p>';
          } else {
            lessonPlayerHost.innerHTML =
              '<video controls preload="metadata" src="' + videoSrc + '" data-video-id="' + videoId + '" data-start-seconds="' + startSeconds + '" controlslist="nodownload noplaybackrate noremoteplayback" disablepictureinpicture></video>' +
              '<div class="lesson-watermark" data-watermark></div>';
            currentVideoEl = lessonPlayerHost.querySelector("video[data-video-id]");
            if (currentVideoEl) {
              attachVideoTracking(currentVideoEl);
            }
          }

          panelCompleteBtn.style.display = "inline-flex";
          panelCompleteBtn.setAttribute("data-video-id", videoId);
          panelCompleteBtn.disabled = completed;
          panelCompleteBtn.textContent = completed ? "Completed" : "Mark as Complete";
        }

        if (searchInput) {
          searchInput.addEventListener("input", applyFilters);
        }
        if (topicFilter) {
          topicFilter.addEventListener("change", applyFilters);
        }
        if (levelFilter) {
          levelFilter.addEventListener("change", applyFilters);
        }

        topicItems.forEach(function (button) {
          button.addEventListener("click", function () {
            selectTopic(button);
          });
        });

        moduleToggles.forEach(function (toggleBtn) {
          toggleBtn.addEventListener("click", function () {
            const moduleCard = toggleBtn.closest(".module-card");
            if (!moduleCard) {
              return;
            }

            const isCollapsed = moduleCard.classList.toggle("module-collapsed");
            toggleBtn.textContent = isCollapsed ? "Expand" : "Collapse";
            toggleBtn.setAttribute("aria-expanded", isCollapsed ? "false" : "true");
          });
        });

        if (panelCompleteBtn) {
          panelCompleteBtn.addEventListener("click", function () {
            const videoId = panelCompleteBtn.getAttribute("data-video-id");
            if (!videoId || panelCompleteBtn.disabled) {
              return;
            }
            markLessonComplete(videoId, panelCompleteBtn);
          });
        }

        if (shareCertBtn && shareCertMsg) {
          shareCertBtn.addEventListener("click", function () {
            fetch("/certificate/share")
              .then(function (r) { return r.json(); })
              .then(function (payload) {
                if (!payload || !payload.url) {
                  shareCertMsg.textContent = "Unable to create share link.";
                  return;
                }
                if (navigator.clipboard && navigator.clipboard.writeText) {
                  navigator.clipboard.writeText(payload.url).then(function () {
                    shareCertMsg.textContent = "Share link copied.";
                  });
                  return;
                }
                shareCertMsg.textContent = payload.url;
              })
              .catch(function () { shareCertMsg.textContent = "Unable to create share link."; });
          });
        }

        applyFilters();
        const firstVisible = Array.from(topicItems).find(function (btn) {
          const li = btn.closest("li");
          return !li || li.style.display !== "none";
        });
        if (firstVisible) {
          selectTopic(firstVisible);
        }
      })();
    </script>
  </body>
</html>
