<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password | CMT Students</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="auth-wrap">
      <section class="card">
        <div class="auth-brand">
          <img src="/logo.svg" alt="Clap Money Trading" class="brand-logo" />
          <p class="brand-subtitle">Clap Money Trading</p>
        </div>

        <h1>Reset Password</h1>

        <% if (error) { %>
          <div class="alert"><%= error %></div>
        <% } %>

        <% if (token) { %>
          <form method="post" action="/reset-password" class="form-grid">
            <input type="hidden" name="token" value="<%= token %>" />

            <label>New Password</label>
            <input type="password" name="password" minlength="6" required />

            <button type="submit">Update Password</button>
          </form>
        <% } %>

        <p class="helper"><a href="/login">Back to Login</a></p>
      </section>
    </main>
  </body>
</html>
