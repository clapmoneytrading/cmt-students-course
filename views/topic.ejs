<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= topic.title %> | Free Trading Topic</title>
    <meta name="description" content="<%= topic.metaDescription %>" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="topbar">
      <div class="brand">
        <img src="/logo.svg" alt="Clap Money Trading" class="brand-logo" />
        <div>
          <h1 class="brand-title">Free Topic</h1>
          <p class="brand-subtitle"><%= topic.title %></p>
        </div>
      </div>
      <div class="topbar-actions">
        <a href="/" class="btn-link">Back to Home</a>
      </div>
    </header>

    <main class="container">
      <section class="card">
        <h2><%= topic.title %></h2>
        <p class="muted"><%= topic.intro %></p>
        <ul>
          <% topic.bullets.forEach((b) => { %>
            <li><%= b %></li>
          <% }) %>
        </ul>
        <a href="/register" class="btn-link">Join Full Learning Portal</a>
      </section>
    </main>

    <a class="whatsapp-float" href="https://wa.me/<%= supportWhatsapp %>" target="_blank" rel="noopener" aria-label="WhatsApp Support">
      WhatsApp Support
    </a>
  </body>
</html>
